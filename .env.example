# cablegram configuration (see src/shared/config).
# Copy to .env for local dev. Never commit .env.

# HTTP
PORT=3000

# MongoDB connection string. cablegram uses the native driver and does only
# single-document, no-transaction writes, so a plain standalone mongod works —
# no replica set needed (ADR-012). Atlas works too. The db name in the path
# (here `cablegram`) is the database the app reads/writes.
DATABASE_URL="mongodb://localhost:27017/cablegram"

# API-key auth (single-tenant; ADR-004, ADR-010). Comma-separated allowed keys.
API_KEYS="dev-key-change-me"

# Postmark (ADR-008). Server token for the Bulk send + a webhook shared secret.
POSTMARK_SERVER_TOKEN="pm-server-token"
POSTMARK_WEBHOOK_SECRET="change-me"
