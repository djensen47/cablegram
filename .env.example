# cablegram configuration (see src/shared/config).
# Copy to .env for local dev. Never commit .env.

# HTTP
PORT=3000

# MongoDB connection string. cablegram uses the native driver and does only
# single-document, no-transaction writes, so a plain standalone mongod works —
# no replica set needed (ADR-012). Atlas works too. The db name in the path
# (here `cablegram`) is the database the app reads/writes.
DATABASE_URL="mongodb://localhost:27017/cablegram"

# JWT auth (ADR-013). `/v1` is protected by a per-user Bearer access token —
# there is no API key. JWT_SECRET signs the HS256 access token and MUST be a
# long, random string (≥32 chars). The TTLs are optional (defaults shown:
# 15m access / 30d refresh). Bootstrap the first admin via POST /v1/setup.
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Postmark (ADR-008). The broadcast server token signs bulk campaign sends; the
# webhook shared secret is the Basic-Auth password on POST /webhooks/postmark.
POSTMARK_SERVER_TOKEN="pm-server-token"
POSTMARK_WEBHOOK_SECRET="change-me"

# Email backend seam — only `postmark` is supported today (optional; default shown).
EMAIL_PROVIDER="postmark"

# Optional distinct Postmark token for TRANSACTIONAL sends (subscribe confirmations
# and account mail). A token is a server in Postmark, so a separate transactional
# server has its own token. Unset → falls back to POSTMARK_SERVER_TOKEN, i.e. a
# single-server setup keeps working unchanged.
# POSTMARK_TRANSACTIONAL_SERVER_TOKEN="pm-transactional-token"

# Account mail (ADR-013/014). Reset + magic-link emails have no newsletter to
# borrow a sender from, so they go out from this system identity. The from-address
# MUST be a Postmark-verified sender/domain. The name is optional (default below).
SYSTEM_EMAIL_FROM_ADDRESS="no-reply@cablegram.example"
SYSTEM_EMAIL_FROM_NAME="cablegram"

# How account emails present the one-time token. cablegram is headless: with links
# OFF (default) the email carries the raw token plus the API path to post it to.
# Set EMAIL_LINK_ENABLED=true to instead link to your front-end — then BOTH base
# URLs are required, and the token is appended as `?token=<token>`.
EMAIL_LINK_ENABLED="false"
# PASSWORD_RESET_URL_BASE="https://app.example.com/reset-password"
# MAGIC_LINK_URL_BASE="https://app.example.com/magic-link"

# One-time token lifetimes (optional; defaults shown: 1h reset / 15m magic-link).
PASSWORD_RESET_TTL_SECONDS=3600
MAGIC_LINK_TTL_SECONDS=900

# Public unsubscribe + RFC 8058 List-Unsubscribe (ADR-015). BASE_URL is the API's
# OWN public origin (e.g. https://api.example.com) — needed so campaign sends can
# emit an absolute List-Unsubscribe link per recipient. Unset → those headers are
# simply omitted and sending is unaffected. No trailing slash needed.
# BASE_URL="https://api.example.com"

# HMAC secret for the stateless, long-lived unsubscribe token. Optional: unset →
# falls back to JWT_SECRET. Set it separately to decouple unsubscribe-link
# validity from JWT-secret rotation. Rotating it invalidates all outstanding links.
# UNSUBSCRIBE_TOKEN_SECRET="change-me-to-a-long-random-secret"

# After a human clicks the body link (a browser GET), optionally redirect them to
# your own landing page (the address is appended as `?email=`). OFF (default) →
# a small generic HTML confirmation is rendered instead. The one-click POST is
# unaffected — it always returns 200. When ON, the URL is required.
UNSUBSCRIBE_REDIRECT_ENABLED="false"
# UNSUBSCRIBE_REDIRECT_URL="https://example.com/unsubscribed"
