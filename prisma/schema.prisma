// cablegram persistence (ADR-007). Prisma on MongoDB, kept to a portable
// subset: string ids app-generated as `_id` (no ObjectId), relations by id
// reference (no embedded documents), so another store stays a swap.
//
// Models are added per domain component (ADR-011): newsletters, subscriptions,
// deliverability, templates, campaigns.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/// A newsletter publication: identity + sender identity + sending-domain/DKIM
/// fields (ADR-011). Portable subset (ADR-007): the id is an app-generated
/// string mapped to `_id` (no `ObjectId`); no embedded documents; timestamps
/// are supplied by the app (injected clock), not database defaults.
model Newsletter {
  id             String   @id @map("_id")
  name           String
  fromName       String
  fromEmail      String
  replyTo        String?
  sendingDomain  String?
  dkimIdentifier String?
  createdAt      DateTime
  updatedAt      DateTime

  @@map("newsletters")
}

/// A global, address-keyed suppression-list entry (ADR-011): a deny-list of
/// addresses cablegram must never send to, regardless of newsletter. Portable
/// subset (ADR-007): the normalized address itself is the id (mapped to
/// `_id`, giving it a unique index for free — no separate `ObjectId`); no
/// embedded documents; the timestamp is supplied by the app (injected clock).
model Suppression {
  address   String   @id @map("_id")
  reason    String
  createdAt DateTime

  @@map("suppressions")
}

/// A flat, per-newsletter subscription (ADR-011): membership belongs to one
/// newsletter by id reference — there is deliberately no cross-newsletter
/// `Contact`, so the same address in two newsletters is two rows. Portable
/// subset (ADR-007): the id is an app-generated string mapped to `_id` (no
/// `ObjectId`); `newsletterId` is a plain id reference (no embedded document);
/// timestamps are supplied by the app (injected clock). `mergeFields` is an
/// opaque per-subscriber JSON merge model (a scalar bag, not a relation) and
/// `tags` a scalar list — both portable to a JSON/array column elsewhere. The
/// compound unique `(newsletterId, email)` is the membership key that makes a
/// subscription unique *within* a newsletter and lets a re-subscribe revive the
/// existing row rather than duplicate it.
model Subscription {
  id           String   @id @map("_id")
  newsletterId String
  email        String
  status       String
  mergeFields  Json
  tags         String[]
  createdAt    DateTime
  updatedAt    DateTime

  @@unique([newsletterId, email])
  @@index([newsletterId])
  @@map("subscriptions")
}

/// A reusable message template: subject plus an HTML body and an optional
/// text body (ADR-011). Portable subset (ADR-007): the id is an app-generated
/// string mapped to `_id` (no `ObjectId`); no embedded documents; timestamps
/// are supplied by the app (injected clock), not database defaults. Body
/// fields hold merge-field template source (untrusted, rendered by the bound
/// `TemplateRenderer`), not raw send-ready content.
model Template {
  id        String   @id @map("_id")
  name      String
  subject   String
  bodyHtml  String
  bodyText  String?
  createdAt DateTime
  updatedAt DateTime

  @@map("templates")
}
